---
import '../../styles/global.css';

// ==========================================
// 0xKIRISAME // TRACKLIST
// To add a new blog entry, just add a new object to this array!
// - title: The track title
// - description: Short summary
// - date: Publication date (YYYY-MM-DD)
// - category: One-word category tag
// - tags: Tech tags separated by " // "
// - link: URL path (internal like "/blog/SPiCa/" or external like "https://...")
// - image: (optional) Cover image path in /public/images/
// - theme: "miku" or "alert" for the track number badge color
// ==========================================
const tracks = [
    {
        title: "SPiCa: Binary Star Systems & Kernel Sovereignty",
        description: "Inspired by the lyrics of a Hatsune Miku song, this post explores how the binary star system of Spica mirrors the relationship between Kernel and User Space, and how eBPF differential analysis can restore harmony when rootkits disrupt it.",
        date: "2026-01-17",
        category: "Philosophy",
        tags: "Rust // eBPF",
        link: "/blog/SPiCa/",
        image: "/images/spica_cover.webp",
        theme: "miku",
    },
    {
        title: "SPiCa 1.2: Security through obscurity and prayers",
        description: "when the hunter becomes the prey he usually go extinct or evolve, some start hunting stealthly while others bruteforce their wins",
        date: "2026-05-26",
        category: "Philosophy",
        tags: "Rust // eBPF // NMI // CO-RE BTF",
        link: "/blog/SPiCa_1.2v/",
        image: "/images/SPiCa_cover2.webp",
        theme: "miku",
    },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRACKLIST // SYSTEM.CORE</title>
    <link rel="icon" href="/images/Tou.png">

    <link rel="preload" href="/fonts/syncopate-700-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />

    <style>
        /* Danmaku Layer */
        #danmaku-layer {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        /* Rhythm Game Track Banner Hover */
        .track-banner {
            transform: skewX(-5deg) translateX(0);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }
        .track-banner:hover {
            transform: skewX(-5deg) translateX(20px);
            box-shadow: 12px 12px 0px 0px #39C5BB;
            background-color: #000;
        }
        .track-banner:hover .track-title { color: #39C5BB; }
        .track-banner:hover .track-desc { color: #FAFAFA; }
        .track-banner:hover .track-meta { border-color: #39C5BB; color: #fff; }
        .track-banner:hover .thumbnail-overlay { opacity: 0; }

        .ribbed-miku {
            background: repeating-linear-gradient(
                45deg,
                #39C5BB,
                #39C5BB 10px,
                transparent 10px,
                transparent 20px
            );
        }
    </style>
</head>
<body class="antialiased selection:bg-miku selection:text-void font-mono bg-paper text-void overflow-x-hidden"
      style="background-image: linear-gradient(#e5e5e5 2px, transparent 2px), linear-gradient(90deg, #e5e5e5 2px, transparent 2px); background-size: 60px 60px;">

    <div id="page-curtain-container" class="fixed inset-0 z-[9999] pointer-events-none bg-white overflow-hidden flex items-center justify-center">
        <div class="absolute w-[300vw] h-[300vh] flex flex-col justify-center items-center -rotate-12">
            <div class="curtain-stripe w-full h-[40vh] bg-void shadow-hard-miku relative z-30"></div>
            <div class="curtain-stripe w-full h-[40vh] bg-miku relative z-20"></div>
            <div class="curtain-stripe w-full h-[40vh] bg-alert shadow-[0_-20px_0_0_#000000] relative z-10"></div>
        </div>
    </div>

    <div id="danmaku-layer"></div>

    <nav class="fixed top-0 left-0 w-full h-16 z-50 flex justify-between items-center px-4 md:px-8 pointer-events-none">
        <a href="/" class="pointer-events-auto page-link bg-void text-miku font-wide font-black text-sm md:text-xl px-6 py-3 border-[4px] border-black shadow-hard-miku hover:bg-miku hover:text-void transition-colors flex items-center gap-4 group">
            <span class="group-hover:-translate-x-2 transition-transform">&lt;&lt; EXIT</span>
        </a>
        <div class="bg-paper border-[4px] border-void px-6 py-3 shadow-hard-black font-wide font-black text-xs md:text-sm tracking-widest pointer-events-auto">
            SYS.CORE // <span class="text-alert animate-pulse">LOG_ARCHIVE</span>
        </div>
    </nav>

    <main class="max-w-[1400px] mx-auto px-4 md:px-8 pt-32 pb-40 z-content relative grid grid-cols-1 lg:grid-cols-12 gap-12">

        <div class="lg:col-span-3 flex flex-col justify-start relative gsap-slide opacity-0">
            <div class="sticky top-32 flex flex-col gap-6">
                <div class="w-24 h-6 ribbed-miku border-[3px] border-void"></div>
                <h1 class="font-wide text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-none text-void" style="writing-mode: vertical-rl; text-orientation: mixed; transform: rotate(180deg);">
                    TRACK<br>
                    <span class="text-transparent" style="-webkit-text-stroke: 3px #000;">LIST</span>
                </h1>
                <div class="font-mono text-xs font-bold uppercase tracking-[0.3em] bg-void text-white p-3 shadow-hard-miku mt-4 self-end">
                    &gt; SELECT_TRANSMISSION
                </div>
            </div>
        </div>

        <div class="lg:col-span-9 flex flex-col gap-8 md:gap-12 mt-12 lg:mt-0" id="track-container">

            {tracks.map((track, i) => {
                const trackNum = String(i + 1).padStart(2, '0');
                const isExternal = track.link.startsWith('http');
                const badgeShadow = track.theme === 'miku' ? '4px_4px_0_0_#39C5BB' : '4px_4px_0_0_#FF0055';

                return (
                    <a href={track.link} target={isExternal ? '_blank' : undefined}
                       class={`gsap-track opacity-0 track-banner wireframe-box block ${!isExternal ? 'page-link' : ''} group relative outline-none`}>
                        <div class="flex flex-col md:flex-row h-full">

                            <div class="w-full md:w-1/3 min-h-[200px] border-b-[4px] md:border-b-0 md:border-r-[4px] border-black relative overflow-hidden bg-void flex-shrink-0 flex items-center justify-center">
                                {track.image ? (
                                    <>
                                        <img src={track.image} class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-500 scale-105 group-hover:scale-100 group-hover:grayscale-0" />
                                        <div class="thumbnail-overlay absolute inset-0 bg-miku mix-blend-screen opacity-50 transition-opacity duration-300"></div>
                                    </>
                                ) : (
                                    <>
                                        <div class="absolute inset-0 ribbed-black opacity-50"></div>
                                        <svg class="w-24 h-24 text-miku opacity-50 group-hover:opacity-100 group-hover:scale-110 transition-all duration-300 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M4 6h16v12H4z"></path></svg>
                                    </>
                                )}
                                <div class={`absolute bottom-4 left-4 bg-void text-white px-3 py-1 font-wide font-black text-2xl shadow-[${badgeShadow}]`}>
                                    TRK_{trackNum}
                                </div>
                            </div>

                            <div class="p-6 md:p-8 flex flex-col justify-between flex-grow bg-paper group-hover:bg-void transition-colors duration-300">
                                <div>
                                    <div class="flex justify-between items-start mb-4">
                                        <h2 class="track-title font-wide text-3xl md:text-4xl font-black text-void uppercase leading-tight">
                                            {track.title}
                                        </h2>
                                    </div>
                                    <p class="track-desc text-gray-700 font-mono font-bold text-sm mb-6 leading-relaxed">
                                        {track.description}
                                    </p>
                                </div>
                                <div class="flex flex-wrap gap-4 mt-auto">
                                    <span class="track-meta border-[3px] border-void text-void px-3 py-1 text-xs font-black uppercase tracking-widest bg-transparent">{track.date}</span>
                                    <span class="track-meta border-[3px] border-void text-void px-3 py-1 text-xs font-black uppercase tracking-widest bg-transparent">{track.category}</span>
                                    <span class="track-meta border-[3px] border-void text-void px-3 py-1 text-xs font-black uppercase tracking-widest bg-transparent">{track.tags}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                );
            })}

        </div>
    </main>

    <div class="fixed top-0 left-0 w-8 h-8 border-t-[6px] border-l-[6px] border-miku z-50 pointer-events-none mix-blend-difference"></div>
    <div class="fixed top-0 right-0 w-8 h-8 border-t-[6px] border-r-[6px] border-miku z-50 pointer-events-none mix-blend-difference"></div>
    <div class="fixed bottom-0 left-0 w-8 h-8 border-b-[6px] border-l-[6px] border-miku z-50 pointer-events-none mix-blend-difference"></div>
    <div class="fixed bottom-0 right-0 w-8 h-8 border-b-[6px] border-r-[6px] border-miku z-50 pointer-events-none mix-blend-difference"></div>

    <script>
        import { gsap } from 'gsap';
        import { initCurtain, initPageTransitions } from '../../scripts/curtain';

        function startBlogDanmaku() {
            const layer = document.getElementById('danmaku-layer');
            const terms = [
                "TRACK_SELECT", "BPM:180", "COMBO_X99", "Aya_eBPF",
                "EXTREME_DIFFICULTY", "0xKIRISAME", "vmlinux", "PERFECT_CLEAR",
                "sys_execve", "kprobe", "bpf_map_lookup", "Vec<u8>",
                "VOCALOID_01", "39's_GIVING_DAY", "SYSTEM.CORE"
            ];

            function spawn() {
                const el = document.createElement('div');
                el.className = 'absolute whitespace-nowrap font-mono text-[0.85rem] text-black/[0.06] font-bold';
                el.innerText = terms[Math.floor(Math.random() * terms.length)];
                el.style.top = `${Math.random() * window.innerHeight}px`;
                el.style.left = '100vw';

                if (layer) {
                    layer.appendChild(el);
                    gsap.to(el, {
                        x: -window.innerWidth - 400,
                        duration: 8 + Math.random() * 12,
                        ease: "none",
                        onComplete: () => el.remove()
                    });
                }
            }
            setInterval(spawn, 400);
            for (let i = 0; i < 30; i++) {
                setTimeout(spawn, Math.random() * 2000);
            }
        }

        window.addEventListener('load', () => {
            initCurtain(gsap);
            initPageTransitions(gsap);

            gsap.fromTo(".gsap-track",
                { x: 150, opacity: 0, skewX: -15 },
                {
                    x: 0,
                    opacity: 1,
                    skewX: -5,
                    duration: 0.8,
                    stagger: 0.2,
                    ease: "power4.out",
                    delay: 1.0,
                    clearProps: "transform"
                }
            );

            if ('requestIdleCallback' in window) {
                requestIdleCallback(() => startBlogDanmaku());
            } else {
                setTimeout(() => startBlogDanmaku(), 1500);
            }
        });
    </script>
</body>
</html>
