---
import '../styles/global.css';
import '../styles/blog.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/images/Tou.png" />
  </head>
  <body class="blog-body antialiased">
    <slot />
  </body>
</html>
